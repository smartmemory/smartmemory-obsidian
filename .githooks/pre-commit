#!/usr/bin/env bash
# Auto-bump patch version when src/ files are staged but package.json
# version is unchanged in this commit. Keeps version-and-shipped-bundle
# parity without relying on memory.
#
# Activate with:
#   git config core.hooksPath .githooks
#
# Skip explicitly with:
#   SKIP_VERSION_BUMP=1 git commit ...
set -euo pipefail

if [[ "${SKIP_VERSION_BUMP:-0}" == "1" ]]; then
  exit 0
fi

# Files that should trigger a version bump when staged
SRC_PATTERN='^(src/|manifest\.json|esbuild\.config\.mjs|main\.js|styles\.css)'

# Are any source files staged?
if ! git diff --cached --name-only | grep -qE "$SRC_PATTERN"; then
  exit 0
fi

# Was package.json's version line itself staged for change?
if git diff --cached -U0 -- package.json | grep -qE '^\+\s*"version"'; then
  # Version already bumped in this commit — make sure manifest.json + versions.json agree
  pkg_ver=$(node -p "require('./package.json').version")
  manifest_ver=$(node -p "require('./manifest.json').version")
  if [[ "$pkg_ver" != "$manifest_ver" ]]; then
    echo "[pre-commit] package.json ($pkg_ver) and manifest.json ($manifest_ver) versions disagree" >&2
    exit 1
  fi
  exit 0
fi

# Auto-bump patch
echo "[pre-commit] Source changes staged; bumping patch version…" >&2
old_ver=$(node -p "require('./package.json').version")
IFS='.' read -r major minor patch <<< "$old_ver"
new_ver="$major.$minor.$((patch + 1))"

# Update package.json
node -e "
  const fs = require('fs');
  const p = JSON.parse(fs.readFileSync('package.json', 'utf8'));
  p.version = '$new_ver';
  fs.writeFileSync('package.json', JSON.stringify(p, null, '\t') + '\n');
"
# Update manifest.json
node -e "
  const fs = require('fs');
  const m = JSON.parse(fs.readFileSync('manifest.json', 'utf8'));
  m.version = '$new_ver';
  fs.writeFileSync('manifest.json', JSON.stringify(m, null, '\t') + '\n');
"
# Update versions.json (Obsidian's compatibility map)
node -e "
  const fs = require('fs');
  const v = JSON.parse(fs.readFileSync('versions.json', 'utf8'));
  const m = JSON.parse(fs.readFileSync('manifest.json', 'utf8'));
  v['$new_ver'] = m.minAppVersion || '1.5.0';
  fs.writeFileSync('versions.json', JSON.stringify(v, null, '\t') + '\n');
"

git add package.json manifest.json versions.json
echo "[pre-commit] Bumped $old_ver → $new_ver" >&2
